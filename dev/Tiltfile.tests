# Tiltfile.tests - @diskd/sdk test and example runners
# All resources are manual-trigger only (no auto-init, no file watch).

namespace = os.getenv('SERVICE_NAMESPACE', 'platform-api')
_ns = namespace + '__'
_label_base = namespace

# -------------------------------------------------------------------------
# Unit tests (no external dependencies)
# -------------------------------------------------------------------------

local_resource(
    _ns + 'test',
    dir='..',
    cmd='npm run test',
    labels=[_label_base + '.tests'],
    auto_init=False,
    trigger_mode=TRIGGER_MODE_MANUAL,
)

# -------------------------------------------------------------------------
# Integration examples (require Drive service running)
# -------------------------------------------------------------------------

local_resource(
    _ns + 'example-session-internal',
    dir='..',
    cmd='npm run examples:session-internal',
    labels=[_label_base + '.examples'],
    auto_init=False,
    trigger_mode=TRIGGER_MODE_MANUAL,
)

local_resource(
    _ns + 'example-session-external',
    dir='..',
    cmd='npm run examples:session-external',
    labels=[_label_base + '.examples'],
    auto_init=False,
    trigger_mode=TRIGGER_MODE_MANUAL,
)

local_resource(
    _ns + 'example-drive-tree',
    dir='..',
    cmd='npm run examples:tree',
    labels=[_label_base + '.examples'],
    auto_init=False,
    trigger_mode=TRIGGER_MODE_MANUAL,
)

local_resource(
    _ns + 'example-smoke',
    dir='..',
    cmd='npm run examples:smoke',
    labels=[_label_base + '.examples'],
    auto_init=False,
    trigger_mode=TRIGGER_MODE_MANUAL,
)
